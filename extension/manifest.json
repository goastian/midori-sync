{
    "manifest_version": 2,
    "name": "Midori Sync",
    "version": "1.0.0",
    "description": "Sync your bookmarks, history, tabs, passwords, and more across all your Midori devices with end-to-end encryption.",
    "author": "Astian",
    "homepage_url": "https://astian.org",

    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },

    "permissions": [
        "storage",
        "bookmarks",
        "history",
        "tabs",
        "alarms",
        "idle"
    ],

    "optional_permissions": [],

    "browser_action": {
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png"
        },
        "default_popup": "popup/popup.html",
        "default_title": "Midori Sync"
    },

    "options_ui": {
        "page": "options/options.html",
        "open_in_tab": true
    },

    "background": {
        "scripts": ["lib/qrcode.min.js", "background/background.js"],
        "persistent": false
    },

    "browser_specific_settings": {
        "gecko": {
            "id": "sync@midori.astian.org",
            "strict_min_version": "109.0"
        }
    }
}
