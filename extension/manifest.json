{
    "manifest_version": 2,
    "name": "Midori Sync",
    "version": "1.0.0",
    "description": "End-to-end encrypted sync for bookmarks, history, tabs, and browser settings across Midori and Firefox devices.",
    "homepage_url": "https://github.com/nickel-org/midori-sync",

    "permissions": [
        "bookmarks",
        "history",
        "tabs",
        "storage",
        "alarms",
        "browserSettings",
        "http://localhost:8000/*",
        "https://sync.astian.org/*",
        "https://accounts.astian.org/*"
    ],

    "background": {
        "scripts": [
            "lib/sodium.js",
            "lib/wordlist.js",
            "lib/midori-sync-crypto.js",
            "background/collection-adapters/bookmarks.js",
            "background/collection-adapters/history.js",
            "background/collection-adapters/tabs.js",
            "background/collection-adapters/browser-settings.js",
            "background/collection-adapters/midori-tab.js",
            "background/collection-adapters/midori-privacy.js",
            "background/background.js"
        ]
    },

    "browser_action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png"
        },
        "default_title": "Midori Sync"
    },

    "options_ui": {
        "page": "options/options.html",
        "browser_style": false
    },

    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },

    "browser_specific_settings": {
        "gecko": {
            "id": "sync@midori.astian.org",
            "strict_min_version": "91.0"
        }
    },

    "content_security_policy": "script-src 'self'; object-src 'self'; connect-src 'self' http://localhost:8000 https://sync.astian.org https://accounts.astian.org; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; default-src 'self'"
}
